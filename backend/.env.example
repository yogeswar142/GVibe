PORT=5000
MONGO_URI=mongodb://localhost:27017/gvibe

# ⚠️  IMPORTANT: Replace this with a long random string in production!
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=gvibe_super_secret_key_change_me_in_production

# Comma-separated list of additional allowed CORS origins (no spaces around commas).
# The ngrok domain and localhost are always included by default.
# Example: ALLOWED_ORIGINS=https://yourapp.com,https://staging.yourapp.com
ALLOWED_ORIGINS=
